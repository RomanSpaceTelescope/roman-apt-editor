<?xml version='1.0' encoding='UTF-8'?>
<RomanProgram xmlns="http://www.stsci.edu/Roman/APT" schemaVersion="31" APTVersion="Version 2026.4  JWST PRD: PRDAPTSOC-073-003, Roman PRD: PRDDEVRSOC-003">
    <ProgramInformation>
        <ProgramPhase>Approved</ProgramPhase>
        <Title>CAR-172: Count-rate dependent nonlinearity (Lamp-on-Lamp-off)</Title>
        <Abstract>LOLO is a superposition test that observes a star field with and without an added flatfield pedestal added, to help retrieve the detector non-linearity.</Abstract>
        <ProgramID>1024</ProgramID>
        <StsciEditNumber>1</StsciEditNumber>
        <ProgramCategory>CAL</ProgramCategory>
        <ProgramCategorySubtype>WFI</ProgramCategorySubtype>
        <AllowRestricted>true</AllowRestricted>
        <IncludesCalibrations>true</IncludesCalibrations>
        <PureParallelProgram>false</PureParallelProgram>
        <Cycle>0</Cycle>
        <ObservingDescription>For this MRT, we observe only one target, NGC6819, which is a stellar cluster in the Kepler field. It offers good number density of stars while maintaining good separation between nearest neighbors.</ObservingDescription>
        <PrincipalInvestigator>
